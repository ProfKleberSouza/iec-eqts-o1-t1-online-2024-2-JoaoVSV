				{
					"name": "Buscar carrinho por ID",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Carrinho encontrado\", function () {\r",
									"    pm.response.to.have.status(200);\r",
									"});\r",
									"\r",
									"pm.test(\"Validação da estrutura de resposta - Buscar carrinho por ID\", function () {\r",
									"    var jsonData = pm.response.json();\r",
									"    jsonData.produtos.forEach(function(produto) {\r",
									"        pm.expect(produto).to.be.an(\"object\");\r",
									"        pm.expect(produto).to.have.property(\"idProduto\").that.is.a(\"string\");\r",
									"        pm.expect(produto).to.have.property(\"quantidade\").that.is.a(\"number\");\r",
									"        pm.expect(produto).to.have.property(\"precoUnitario\").that.is.a(\"number\");\r",
									"    });\r",
									"    pm.expect(jsonData).to.have.property(\"precoTotal\").that.is.an(\"number\");\r",
									"    pm.expect(jsonData).to.have.property(\"quantidadeTotal\").that.is.an(\"number\");\r",
									"    pm.expect(jsonData).to.have.property(\"idUsuario\").that.is.an(\"string\");\r",
									"    pm.expect(jsonData).to.have.property(\"_id\").that.is.an(\"string\");\r",
									"\r",
									"});\r",
									""
								],
								"type": "text/javascript",
